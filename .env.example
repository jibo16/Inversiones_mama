# Inversiones_mama — API keys template
# Copy this file to .env and fill in real values. NEVER commit .env.

# Alpha Vantage — https://www.alphavantage.co
# Free tier: 25 calls/day, 5 calls/min. Used for: fundamentals, news sentiment, technical indicators.
ALPHAVANTAGE_API_KEY=your_key_here

# Finnhub — https://finnhub.io
# Free tier: 60 calls/min. Used for: real-time quotes, earnings calendar, deep fundamentals.
FINNHUB_API_KEY=your_key_here

# Interactive Brokers — connection settings (no API key; handled via TWS/Gateway login)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=DU_paper_account_here
IBKR_CP_BASE_URL=https://localhost:5000/v1/api
IBKR_CP_WS_URL=wss://localhost:5000/v1/api/ws
IBKR_CP_VERIFY_SSL=false
IBKR_MARKET_DATA_FIELDS=31,84,85,86,88,7059,6509

# FRED (St. Louis Fed) — free, optional
FRED_API_KEY=optional_for_macro_data

# Alpaca Markets — paper trading sandbox (ExecutionClient Protocol)
# Paper credentials: https://app.alpaca.markets/paper/dashboard/overview
# Live credentials: https://app.alpaca.markets/live/dashboard/overview
# Paper base URL (default). Switch to api.alpaca.markets for live trading.
ALPACA_API_KEY_ID=your_paper_key_here
ALPACA_API_SECRET_KEY=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
